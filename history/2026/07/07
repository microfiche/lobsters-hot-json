[{"short_id":"5rvgim","created_at":"2026-07-07T01:20:55.000-05:00","title":"Odin 1.0 Announcement","url":"https://www.youtube.com/watch?v=dLPAqXi9In0","score":81,"flags":1,"comment_count":14,"description":"","description_plain":"","submitter_user":"gingerBill","user_is_author":true,"tags":["plt","programming","video"],"short_id_url":"https://lobste.rs/s/5rvgim","comments_url":"https://lobste.rs/s/5rvgim/odin_1_0_announcement"},{"short_id":"709awc","created_at":"2026-07-07T04:35:02.000-05:00","title":"Together for a healthier Clippy","url":"https://blog.rust-lang.org/inside-rust/2026/07/06/unite-for-clippy/","score":47,"flags":0,"comment_count":9,"description":"","description_plain":"","submitter_user":"blyxyas","user_is_author":true,"tags":["rust"],"short_id_url":"https://lobste.rs/s/709awc","comments_url":"https://lobste.rs/s/709awc/together_for_healthier_clippy"},{"short_id":"8d9pgd","created_at":"2026-07-07T08:13:47.000-05:00","title":"You shouldn't trust Trusted Publishing","url":"https://blog.yossarian.net/2026/07/07/You-shouldnt-trust-trusted-publishing","score":13,"flags":0,"comment_count":1,"description":"","description_plain":"","submitter_user":"yossarian","user_is_author":true,"tags":["python","security"],"short_id_url":"https://lobste.rs/s/8d9pgd","comments_url":"https://lobste.rs/s/8d9pgd/you_shouldn_t_trust_trusted_publishing"},{"short_id":"v8hk8q","created_at":"2026-07-07T02:33:16.000-05:00","title":"Google’s exponential path to climate-wrecking digital bloat","url":"https://ketanjoshi.co/2026/07/01/googles-exponential-path-to-climate-wrecking-digital-bloat/","score":46,"flags":0,"comment_count":1,"description":"","description_plain":"","submitter_user":"sjamaan","user_is_author":false,"tags":["vibecoding"],"short_id_url":"https://lobste.rs/s/v8hk8q","comments_url":"https://lobste.rs/s/v8hk8q/google_s_exponential_path_climate"},{"short_id":"no3kkj","created_at":"2026-07-07T03:22:58.000-05:00","title":"Why false sharing alignment should be 128 bytes on